# ══════════════════════════════════════════════════════════════════════════════
# Copiar a .env y completar TODOS los valores antes de hacer docker compose up
# ══════════════════════════════════════════════════════════════════════════════

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.XXXXX.mongodb.net/workflow_db?retryWrites=true&w=majority

# ── Spring Boot ───────────────────────────────────────────────────────────────
JWT_SECRET=cambiar_por_clave_aleatoria_larga_minimo_32_caracteres

# Dominio sslip.io: tu IP pública seguida de .sslip.io
# Ejemplo: IP 54.234.12.56 → DOMAIN=54.234.12.56.sslip.io
DOMAIN=TU_IP_PUBLICA.sslip.io

# URL pública (sin barra final). Usada para CORS en Spring Boot.
# Mientras no tengas HTTPS: http://TU_IP_PUBLICA_EC2
# Después de obtener el cert: https://TU_IP_PUBLICA.sslip.io
FRONTEND_URL=https://TU_IP_PUBLICA.sslip.io

# ── Claude AI ─────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# ── Credenciales del servicio TensorFlow para autenticarse en Spring Boot ─────
# Debe ser un usuario que ya exista en tu base de datos.
# Puedes usar tu usuario administrador o crear uno dedicado (ej: tf-service@app.com).
TF_SPRING_EMAIL=usuario@tudominio.com
TF_SPRING_PASSWORD=contraseña_del_usuario

# ── Firebase (notificaciones push) ───────────────────────────────────────────
# JSON del service account en una sola línea (sin saltos de línea)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
AWS_BUCKET_NAME=
AWS_KEY_PREFIX=tramites
